{
  "name": "verijob-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "test": "node --test tests/**/*.test.mjs",
    "test:company-candidate-import": "node --test tests/company-candidate-import.test.mjs",
    "test:smoke": "playwright test tests/smoke",
    "test:smoke:auth": "playwright test tests/smoke --grep @auth",
    "test:smoke:beta": "playwright test tests/smoke --grep @beta-gate",
    "test:smoke:candidate": "playwright test tests/smoke --grep @candidate",
    "test:smoke:company": "playwright test tests/smoke --grep @company",
    "test:smoke:owner": "playwright test tests/smoke --grep @owner",
    "test:smoke:public-profile": "playwright test tests/smoke --grep @public-profile",
    "test:smoke:headed": "playwright test tests/smoke --headed",
    "test:live:auth": "playwright test --config playwright.live-auth.config.ts",
    "test:live:candidate": "SMOKE_AUTH_SETUP_SCOPE=candidate playwright test tests/smoke/smoke-candidate.spec.ts --config playwright.live-smoke.config.ts --project chromium",
    "test:live:unlock": "SMOKE_AUTH_SETUP_SCOPE=company playwright test tests/smoke/company-public-unlock-live.spec.ts --config playwright.live-smoke.config.ts --project chromium",
    "test:live:owner": "SMOKE_AUTH_SETUP_SCOPE=owner playwright test tests/smoke/smoke-owner.spec.ts --config playwright.live-smoke.config.ts --project chromium",
    "playwright:install": "playwright install chromium",
    "lint": "eslint",
    "postbuild": "node scripts/vercel-fix-missing-manifests.cjs",
    "cleanup:test-users": "tsx scripts/cleanup-test-users.ts",
    "stripe:catalog:live": "node scripts/stripe/create-live-catalog.cjs scripts/stripe/verijob-catalog-live-v2.json",
    "demo:seed:marta": "node scripts/demo/seed-marta-gil-ortega.mjs seed",
    "demo:rollback:marta": "node scripts/demo/seed-marta-gil-ortega.mjs rollback"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "mammoth": "^1.11.0",
    "next": "16.1.6",
    "pdf-parse": "^2.4.5",
    "pdf-parse-debugging-disabled": "^1.1.1",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^20.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "^5"
  }
}
