
-- F22: Owner Control Center (Growth + Marketing)

create extension if not exists pgcrypto;

create table if not exists public.growth_campaigns (
  id uuid primary key default gen_random_uuid(),
  created_by uuid not null,
  objective text not null,
  sector text not null,
  location_scope text not null,
  location_value text,
  company_size text not null,
  channel text not null,
  intensity text not null,
  message_style text not null,
  template_key text,
  status text not null default 'draft',
  execution_mode text not null default 'manual',
  orchestration_status text not null default 'ready',
  launched_at timestamptz,
  paused_at timestamptz,
  closed_at timestamptz,
  leads_discovered int not null default 0,
  contacts_found int not null default 0,
  messages_queued int not null default 0,
  replies_count int not null default 0,
  demos_count int not null default 0,
  metadata jsonb not null default '{}'::jsonb,
  created_at timestamptz not null default now(),
  updated_at timestamptz not null default now(),
  constraint growth_campaigns_status_check check (status in ('draft','running','paused','closed'))
);

create index if not exists growth_campaigns_created_at_idx on public.growth_campaigns(created_at desc);
create index if not exists growth_campaigns_status_idx on public.growth_campaigns(status);

create table if not exists public.promo_codes (
  id uuid primary key default gen_random_uuid(),
  code text not null unique,
  target_type text not null,
  benefit_type text not null,
  benefit_value text,
  duration_days int,
  starts_at timestamptz,
  expires_at timestamptz,
  max_redemptions int,
  current_redemptions int not null default 0,
  is_active boolean not null default true,
  campaign_type text,
  metadata jsonb not null default '{}'::jsonb,
  created_by uuid not null,
  created_at timestamptz not null default now()
);

create index if not exists promo_codes_active_idx on public.promo_codes(is_active, created_at desc);
create index if not exists promo_codes_campaign_type_idx on public.promo_codes(campaign_type);

create table if not exists public.promo_code_redemptions (
  id uuid primary key default gen_random_uuid(),
  promo_code_id uuid not null references public.promo_codes(id) on delete cascade,
  user_id uuid not null,
  redeemed_at timestamptz not null default now(),
  applied_plan text,
  expires_at timestamptz,
  status text not null default 'active'
);

create index if not exists promo_code_redemptions_code_idx on public.promo_code_redemptions(promo_code_id);
create index if not exists promo_code_redemptions_user_idx on public.promo_code_redemptions(user_id);

create table if not exists public.manual_grants (
  id uuid primary key default gen_random_uuid(),
  user_id uuid not null,
  grant_type text not null,
  grant_value text,
  reason text not null,
  starts_at timestamptz not null default now(),
  expires_at timestamptz,
  granted_by uuid not null,
  status text not null default 'active',
  metadata jsonb not null default '{}'::jsonb,
  created_at timestamptz not null default now()
);

create index if not exists manual_grants_user_idx on public.manual_grants(user_id, created_at desc);
create index if not exists manual_grants_status_idx on public.manual_grants(status);

create table if not exists public.plan_overrides (
  id uuid primary key default gen_random_uuid(),
  user_id uuid not null,
  plan_key text not null,
  source_type text not null,
  source_id uuid,
  starts_at timestamptz not null default now(),
  expires_at timestamptz,
  is_active boolean not null default true,
  metadata jsonb not null default '{}'::jsonb,
  created_at timestamptz not null default now()
);

create index if not exists plan_overrides_user_active_idx on public.plan_overrides(user_id, is_active, created_at desc);

create table if not exists public.credit_grants (
  id uuid primary key default gen_random_uuid(),
  user_id uuid not null,
  credits int not null,
  source_type text not null,
  source_id uuid,
  starts_at timestamptz not null default now(),
  expires_at timestamptz,
  is_active boolean not null default true,
  granted_by uuid not null,
  metadata jsonb not null default '{}'::jsonb,
  created_at timestamptz not null default now()
);

create index if not exists credit_grants_user_idx on public.credit_grants(user_id, created_at desc);

-- Security baseline: client access closed by default, owner workflows via server-side API (service role)
alter table public.growth_campaigns enable row level security;
alter table public.promo_codes enable row level security;
alter table public.promo_code_redemptions enable row level security;
alter table public.manual_grants enable row level security;
alter table public.plan_overrides enable row level security;
alter table public.credit_grants enable row level security;

alter table public.growth_campaigns force row level security;
alter table public.promo_codes force row level security;
alter table public.promo_code_redemptions force row level security;
alter table public.manual_grants force row level security;
alter table public.plan_overrides force row level security;
alter table public.credit_grants force row level security;

revoke all on table public.growth_campaigns from anon, authenticated;
revoke all on table public.promo_codes from anon, authenticated;
revoke all on table public.promo_code_redemptions from anon, authenticated;
revoke all on table public.manual_grants from anon, authenticated;
revoke all on table public.plan_overrides from anon, authenticated;
revoke all on table public.credit_grants from anon, authenticated;

drop policy if exists growth_campaigns_deny_all on public.growth_campaigns;
create policy growth_campaigns_deny_all on public.growth_campaigns
  for all to anon, authenticated
  using (false)
  with check (false);

drop policy if exists promo_codes_deny_all on public.promo_codes;
create policy promo_codes_deny_all on public.promo_codes
  for all to anon, authenticated
  using (false)
  with check (false);

drop policy if exists promo_code_redemptions_deny_all on public.promo_code_redemptions;
create policy promo_code_redemptions_deny_all on public.promo_code_redemptions
  for all to anon, authenticated
  using (false)
  with check (false);

drop policy if exists manual_grants_deny_all on public.manual_grants;
create policy manual_grants_deny_all on public.manual_grants
  for all to anon, authenticated
  using (false)
  with check (false);

drop policy if exists plan_overrides_deny_all on public.plan_overrides;
create policy plan_overrides_deny_all on public.plan_overrides
  for all to anon, authenticated
  using (false)
  with check (false);

drop policy if exists credit_grants_deny_all on public.credit_grants;
create policy credit_grants_deny_all on public.credit_grants
  for all to anon, authenticated
  using (false)
  with check (false);
